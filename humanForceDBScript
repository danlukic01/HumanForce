CREATE VIEW [dbo].[TimesheetData]
AS
SELECT DISTINCT 
	Timesheet.GuidKey AS TimesheetGuidKey,
	Timesheet.DateStart, 
	Employee.GuidKey AS EmployeeGuidKey,
	Employee.EmployeeCode, 
	Employee.Name AS EmployeeName, 
	Employee.FirstName, 
	Employee.LastName, 
	Employee.DateOfBirth, 
	Gender.GuidKey AS GenderGuidKey,
	Gender.ShortName AS Gender, 
	Employee.StartDate, 
	Employee.TerminationDate, 
	Role.GuidKey AS RoleGuidKey,
	Role.Name AS RoleName, 
	Department.GuidKey AS DepartmentGuidKey,
	Department.Name AS DepartmentName, 
	Location.GuidKey AS LocationGuidKey,
	Location.Name AS LocationName, 
	Area.GuidKey AS AreaGuidKey,
	Area.Name AS AreaName, 
	Employee.PayrollCode, 
	EmploymentType.GuidKey AS EmploymentTypeGuidKey,
	EmploymentType.Name AS EmploymentTypeName, 
	PayRate.GuidKey AS PayRateGuidKey,
	PayRate.Name AS PyRateName, 
	PayCompany.GuidKey AS PayCompanyGuidKey,
	PayCompany.Name AS PayCompanyName, 
	Employee.DefaultHourlyRate, 
	PayRate.Rate, 
	ShiftType.GuidKey AS ShiftTypeGuidKey,
	ShiftType.Name AS ShiftTypeName, 
	ShiftType.IsNormalType, 
	ShiftType.IsUnPaid, 
	ShiftType.IsAttendedType, 
	ShiftType.IsLeaveType, 
	ShiftType.IsUnplannedLeave, 
	Roster.GuidKey AS RosterGuidKey,
	Roster.GuidKey AS RosterKey, 
	Timesheet.RosterStartTime, 
	Timesheet.RosterEndTime, 
	Roster.GrossMinutes AS RosterGrossMinutes, 
	Roster.BreakMinutes AS RosterBreakMinutes, 
	Roster.NetMinutes AS RosterNetMinutes, 
	Roster.Cost AS RosterCost, 
	Timesheet.ClockedStartTime, 
	Timesheet.ClockedEndTime, 
	Timesheet.GrossMinutes AS TimsheetGrossMinutes, 
	Timesheet.BreakMinutesUnpaid AS TimesheetBreakMinutesUnpaid, 
	Timesheet.BreakMinutesPaid AS TimesheetBreakMinutesPaid, 
	Timesheet.NetMinutes AS TimesheetNetMinutes, 
	Timesheet.Cost AS TimesheetCost, 
	Timesheet.Authorised, 
	Timesheet.Paid, 
	Timesheet.PayStartTime, 
	Timesheet.PayEndTime
FROM Timesheet
	LEFT JOIN Roster ON (Timesheet.RosterGuidKey = Roster.GuidKey)
	LEFT JOIN Employee ON (Timesheet.Employee = Employee.GuidKey)
	LEFT JOIN ShiftType ON (Timesheet.ShiftType = ShiftType.GuidKey)
	LEFT JOIN Role ON (Employee.DefaultRole = Role.GuidKey)
	LEFT JOIN Area ON (Timesheet.Area = Area.GuidKey)
	LEFT JOIN Location ON (Timesheet.Location = Location.GuidKey)
	LEFT JOIN Department ON (Employee.DefaultDepartment = Department.GuidKey)
	LEFT JOIN PayRate ON (Employee.DefaultPayRate = PayRate.GuidKey)
	LEFT JOIN EmploymentType ON (Employee.EmploymentType = EmploymentType.GuidKey)
	LEFT JOIN PayCompany ON (Employee.PayCompany = PayCompany.GuidKey)
	LEFT JOIN Gender ON (Employee.Gender = Gender.GuidKey);
